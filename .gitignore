# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# generated data: photos + vector index are reproducible from the committed
# corpus (data/cvs) via `npm run ingest`; personas.json and the PDFs are
# committed so reviewers can run the app without generating anything.
/data/photos/
/data/index.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

